# Firebase 콘솔 > 프로젝트 설정 > 일반 > 내 앱(웹 앱) 에서 복사해서
# 이 파일을 복사한 뒤 이름을 .env.local 로 바꾸고 실제 값을 채워넣으세요.
# .env.local은 git에 올리면 안 됩니다 (이미 .gitignore에 포함되어 있어요).

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# aistudio.google.com > Get API key 에서 무료로 발급.
# "메모에서 가져오기" AI 분류 기능에 사용돼요 (Gemini 2.5 Flash-Lite, 무료 티어). 서버에서만 쓰이므로 NEXT_PUBLIC_ 접두사가 없어요.
GEMINI_API_KEY=
