rules_version = '2';

// 팩인백 Firestore 보안 규칙
// - users/{uid}: 본인만 읽고 쓸 수 있음
// - users/{uid}/libraryPacks: 팩 라이브러리는 공유되지 않는 개인 전용 공간. 본인만 접근.
//   단, 새로 만들기(create)는 무료 개수 제한을 서버에서 검증해야 해서 클라이언트로는 막아뒀고
//   (allow create: if false), app/api/create-library-pack(Admin SDK)에서만 만들 수 있다.
//   기존 팩 수정(자동저장)/삭제는 여전히 클라이언트가 직접 하지만, locked:true인 팩(이용권이
//   없거나 만료/무효화된 상태에서 라이브러리 개수 제한을 넘은 것)은 서버(app/api/
//   sync-lock-status)만 고칠 수 있고 클라이언트 쪽 수정/삭제는 막힌다(읽기는 계속 허용).
// - bags/{bagId}: 공유 단위는 "가방"이다. memberIds에 포함된 사람만 읽고 쓸 수 있음(동시편집).
//   생성(create)은 무료 개수 제한을 서버에서 검증해야 해서 클라이언트로는 막아뒀고(allow
//   create: if false), app/api/create-bag(Admin SDK)에서만 만들 수 있다. 참여는 초대코드를
//   아는 사람이 자기 uid만 추가하는 형태로만 허용(이건 여전히 클라이언트 직접 update).
//   가방이 locked:true(소유자가 무료 전환 후 개수 제한을 넘어선 상태)이면, "소유자" 본인의
//   수정/삭제만 막힌다 - 다른 그룹원은 locked 여부와 무관하게 그대로 이용할 수 있다
//   (request.auth.uid == ownerId 조건과 함께 검사). locked 필드 자체도 app/api/
//   sync-lock-status(Admin SDK)만 쓸 수 있다.
// - bags/{bagId}/presence: 그 가방 멤버만 자신의 접속 상태를 쓸 수 있음(실시간 접속자 표시용).
// - inviteCodes/{code}: 코드 -> bagId 매핑. 코드를 아는 사람만 조회 가능(목록조회는 불가).
// - announcements/{id}: 공지사항. 로그인한 사람 누구나 읽고, 마스터(운영자) 이메일만 쓸 수 있음.
// - unlockCodes/{code}: AI 기능 무제한 이용권 코드. 코드를 아는 사람은 존재 여부만 조회(get) 가능,
//   목록조회(list)/생성은 마스터(운영자)만 가능. 코드를 실제로 "사용 처리(claim)"하는 것은
//   클라이언트가 아니라 서버(Admin SDK, app/api/redeem-unlock-code)만 할 수 있다 - 그래서 일반
//   사용자에게는 update 권한이 전혀 없다. 마스터는 이미 발급된 코드를 "무효화(invalidate)"만
//   할 수 있고, 그 외 필드(claimedBy 등)는 절대 건드릴 수 없다.
//
// 참고: "소그룹(최대 10명)" 신뢰 기반 사용을 가정한 1차 버전입니다.
// bags 컬렉션 자체에 대한 규칙은 resource.data를 직접 사용하고(추가 get() 호출 없음),
// 부모 가방의 멤버인지 확인해야 하는 하위 presence 문서에서만 get()을 사용한다.

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // 팩 라이브러리 새로 만들기(create)는 무료 개수 제한(FREE_MAX_LIBRARY_PACKS)을
      // 서버에서 검증해야 해서 app/api/create-library-pack에서만 가능하다(Admin SDK는
      // 이 규칙을 그대로 통과한다). 기존 팩 수정/삭제는 여전히 클라이언트가 직접 한다.
      match /libraryPacks/{packId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        // 잠긴(locked:true) 팩은 서버(app/api/sync-lock-status, Admin SDK)만 수정/삭제할 수
        // 있다 - 클라이언트 직접 update/delete는 resource.data.locked가 true가 아니어야만 허용된다.
        allow update, delete: if request.auth != null && request.auth.uid == uid &&
          resource.data.get('locked', false) != true;
        allow create: if false;
      }
    }

    // 초대코드 -> 가방id 매핑. 코드를 아는 사람이면 조회 가능(참여 전이라 멤버가 아니어도 됨).
    // list(전체 목록 조회)는 금지되어 있어 코드를 모르면 뒤질 수 없음.
    match /inviteCodes/{code} {
      allow get: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // 공지사항: 로그인한 사람 누구나 읽을 수 있고, 마스터(운영자) 이메일만 쓸 수 있다.
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.token.email in ['appfle.dev@gmail.com', 'appfle.io@gmail.com', 'dg931217@naver.com'];
    }

    // AI 이용권 코드: 코드를 아는 사람이면 존재 여부만 조회 가능(get, 참여처럼 목록조회는 금지).
    // 마스터(운영자)는 전체 목록 조회 + 새 코드 생성이 가능 (이용권 코드 관리 화면용).
    match /unlockCodes/{code} {
      allow get: if request.auth != null;
      allow list: if request.auth != null &&
        request.auth.token.email in ['appfle.dev@gmail.com', 'appfle.io@gmail.com', 'dg931217@naver.com'];
      allow create: if request.auth != null &&
        request.auth.token.email in ['appfle.dev@gmail.com', 'appfle.io@gmail.com', 'dg931217@naver.com'];

      // 마스터가 "무효화" 버튼을 눌렀을 때만 허용: status/invalidatedAt 두 필드만 바꿀 수 있고,
      // 반드시 'invalidated'로 바꾸는 경우만 허용한다 (claimedBy 등 위조 불가).
      allow update: if request.auth != null &&
        request.auth.token.email in ['appfle.dev@gmail.com', 'appfle.io@gmail.com', 'dg931217@naver.com'] &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'invalidatedAt']) &&
        request.resource.data.status == 'invalidated';

      allow delete: if false;
    }

    match /bags/{bagId} {
      allow read: if request.auth != null &&
        request.auth.uid in resource.data.memberIds;

      // 가방 새로 만들기(create)는 무료 동시 진행 개수 제한(FREE_MAX_ACTIVE_BAGS)을
      // 서버에서 검증해야 해서 app/api/create-bag에서만 가능하다(Admin SDK는 이 규칙을
      // 그대로 통과하므로 실제로는 그 라우트를 통해서만 생성된다). 기존 가방 수정/삭제,
      // 초대코드로 참여하는 것은 여전히 클라이언트가 직접 한다.
      allow create: if false;

      // 이미 멤버인 사람의 일반 수정(멤버 목록을 줄이는 탈퇴 포함, memberIds 추가는 불가).
      // 가방이 locked:true이고 지금 수정하는 사람이 이 가방의 소유자(ownerId)라면 거부된다 -
      // 다른 그룹원이 수정하는 건 locked 여부와 무관하게 계속 허용된다.
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.memberIds &&
        !(request.auth.uid == resource.data.ownerId && resource.data.get('locked', false) == true) &&
        (
          request.resource.data.memberIds.size() <= resource.data.memberIds.size() ||
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['memberIds'])
        );

      // 아직 멤버가 아닌 사용자가 초대코드로 참여할 때: 자기 uid 하나만 추가 허용
      // (memberProfiles.{uid} 스냅샷도 함께 기록할 수 있게 허용)
      allow update: if request.auth != null &&
        !(request.auth.uid in resource.data.memberIds) &&
        request.resource.data.memberIds == resource.data.memberIds.concat([request.auth.uid]) &&
        resource.data.memberIds.size() < 10 &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'memberProfiles']);

      // 가방 삭제도 수정과 동일하게: locked:true인 가방은 소유자 본인이라면 삭제할 수 없다 -
      // 다른 그룹원(탈퇴 대상)도 memberIds에 있는 한 이 규칙을 타니, 소유자가 아니라면 당연히 허용된다.
      allow delete: if request.auth != null &&
        request.auth.uid in resource.data.memberIds &&
        !(request.auth.uid == resource.data.ownerId && resource.data.get('locked', false) == true);

      match /presence/{presenceUid} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/bags/$(bagId)).data.memberIds;
        allow write: if request.auth != null &&
          request.auth.uid == presenceUid &&
          request.auth.uid in get(/databases/$(database)/documents/bags/$(bagId)).data.memberIds;
      }
    }
  }
}
