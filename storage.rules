rules_version = '2';

// 팩인백 Storage 보안 규칙
// 경로: bags/{bagId}/{fileName}
// 해당 가방의 멤버만 읽고 쓸 수 있고, 이미지 파일만, 5MB 이하만 업로드 가능.
//
// 주의: 같은 경로에 allow write를 여러 번 쓰면 OR로 합쳐진다(하나만 만족해도 허용됨).
// 그래서 "인증+멤버십" 조건과 "용량+타입" 조건을 반드시 하나의 allow write 안에서
// &&로 묶어야 한다 (분리하면 용량/타입만 맞으면 로그인 없이도 쓰기가 허용되는 구멍이 생김).

service firebase.storage {
  match /b/{bucket}/o {
    match /bags/{bagId}/{fileName} {
      allow read: if request.auth != null &&
        request.auth.uid in firestore.get(/databases/(default)/documents/bags/$(bagId)).data.memberIds;

      allow write: if request.auth != null &&
        request.auth.uid in firestore.get(/databases/(default)/documents/bags/$(bagId)).data.memberIds &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }
  }
}
