rules_version = '2';

// 팩인백 Storage 보안 규칙
// 경로: bags/{bagId}/{fileName}
// 해당 가방의 멤버만 읽고 쓸 수 있고, 이미지 파일만, 5MB 이하만 업로드 가능.
// 가방이 locked:true(소유자가 무료 전환 후 개수 제한을 넘어선 상태)이고 지금 업로드하는
// 사람이 그 가방의 소유자(ownerId)라면, 업로드가 거부된다 - 다른 그룹원은 locked 여부와
// 무관하게 여전히 업로드할 수 있다(firestore.rules에서 가방 수정/삭제를 막는 것과 동일한 원칙).
//
// 주의: 같은 경로에 allow write를 여러 번 쓰면 OR로 합쳐진다(하나만 만족해도 허용됨).
// 그래서 "인증+멤버십" 조건과 "용량+타입" 조건을 반드시 하나의 allow write 안에서 &&로
// 묶어야 한다 (분리하면 용량/타입만 맞으면 로그인 없이도 쓰기가 허용되는 구멍이 생김).

service firebase.storage {
  match /b/{bucket}/o {
    match /bags/{bagId}/{fileName} {
      allow read: if request.auth != null &&
        request.auth.uid in firestore.get(/databases/(default)/documents/bags/$(bagId)).data.memberIds;

      allow write: if request.auth != null &&
        request.auth.uid in firestore.get(/databases/(default)/documents/bags/$(bagId)).data.memberIds &&
        !(
          request.auth.uid == firestore.get(/databases/(default)/documents/bags/$(bagId)).data.ownerId &&
          firestore.get(/databases/(default)/documents/bags/$(bagId)).data.get('locked', false) == true
        ) &&
        request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }
  }
}
